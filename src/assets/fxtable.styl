$active_menu_color= var(--color-active-menu)
$base_font_size = 16
$px = (1/$base_font_size) rem
colors = #0D61AB, #E48203, #7AC528, #842A7C, #9A012D

tr  // this bad style 
		for num in 1 2 3    
			nth-child(num)
// this how to do it 
for color, i in colors
	li:nth-child({i + 1})
		color color		
th-g()
	padding 0.2em 0.15em
	text-align left
	font-weight 500
	font-size 16*$px
	color #fff
	text-transform uppercase
	width 0
	min-width 50*$px
	white-space nowrap
	text-shadow 2*$px 1*$px 1*$px rgba(252, 175, 12, 0.5)
	border-radius 0.1rem
tr-a()
	margin 0.25rem
	border-bottom solid 2*$px rgba(235, 246, 243, 0.8)
	border-top  solid 2*$px rgba(235, 246, 243, 0.7)
	font-weight 400
	text-shadow: 2*$px 1*$px 1*$px rgba(222, 75, 12, 0.5);
	padding 0.35em
	font-size 15*$px
	background linear-gradient(to top, #0d8c81, #54d3de)
td-g()
	padding 0.15em
	text-align left
	vertical-align middle
	font-weight 300
	font-size 14*$px
	color #fff
	width 0
	max-width 50*$px
	min-width: fit-content;
	white-space: nowrap;
	border-bottom solid 1*$px rgba(255,255,255,0.1)
	
	&:hover
		&:before
			content: "";
			position: absolute;
			left: 0;
			right: 0;
			top: -9999px;
			bottom: -9999px;
			background-color: rgba(255,255,255,0.2);
			z-index: -1;
thd()
	width 100%
	table-layout fixed
	box-sizing: border-box
.tbl-header
	background-color rgba(255,255,255,0.3)

.tbl-content
	height 300*$px
	overflow-x auto
	margin-top 0px
	border 1*$px solid rgba(255,255,255,0.3)
	&.full
		height 80vh
.fx-tb
	background: linear-gradient(to right, #0b756c, #25b7c4)
	thd()
	thead
		tr
			background: linear-gradient(to top, #0b756c, #25b7c4)
		th
			th-g()
	for i in (0..13)
		th:nth-child({i + 1})
			if i==2
				width 26.5%
			else 
				width 7.5%
			if i==4 || i==5
				width 4%
			if i==6 || i==7
				width 2.5%
				text-align center
			if i==8 || i==9
				width 6%
				text-align center
			if i==1
				text-align center
				width 8%
			if i==0
				padding-left 1rem		
			
	tr
		text-shadow 2px 1px 1px rgba(243, 240, 209, 0.3)
		&:hover
			background-color: rgba(255,255,255,0.3)
			color red !important;
		.active
			tr-a()
	td
		td-g()
	for i in (0..13)
		td:nth-child({i + 1})
			if i==2
				width 26.5% 
			else 
				width 7.5%
			if i==4 || i==5
				width 4%
			if i==6 || i==7
				width 2.5%
				text-align center
			if i==8 || i==9
				width 6%
				text-align center	
			if i==1 
				text-align center
				width 8%
			if i==0
				padding-left 0.5rem
.xtb
	for i in (0..13)
		th:nth-child({i + 1})
		td:nth-child({i + 1})	
			if i==2
				width 24%
			else 
				width 5.2%
				text-align center
			if i==0
				width 8%
			if i==6
				width 8%		  
				
.even
	background: linear-gradient(to left, #25b7c4, #11bbad) 
.fx-tbl
	background: linear-gradient(to left, #0b756c, #25b7c4)
	thd()
	thead
		tr
			background: linear-gradient(to top, #0b756c, #25b7c4)
			th
				th-g()
	tr
		text-shadow 2px 1px 1px rgba(243, 240, 209, 0.3)
		&:hover
			background-color: rgba(255,255,255,0.3)
			color red !important;
		.active
			tr-a()
	// tr:nth-child(even)
	// 	background: linear-gradient(to left, #25b7c4, #0b756c) 		
	td
		td-g()
		width: auto !important;
	.td-big
		text-align center
		font-size $base_font_size*2*$px
	
				
			

::-webkit-scrollbar
	width 15*$px

::-webkit-scrollbar-track
	-webkit-box-shadow inset 0 0 25*$px rgba(0,0,0,0.3)

::-webkit-scrollbar-thumb
	-webkit-box-shadow inset 0 0 25*$px rgba(0,0,0,0.3)    

@media (max-width: 1400px)
	.fx-tb,.fx-tbl
		thead
			tr
				th
					font-weight 450
					font-size 15*$px
		tr			
			td
				font-size 13*$px		
@media (max-width: 1200px)
	.fx-tb,.fx-tbl
		thead
			tr
				th
					font-weight 400
					font-size 14*$px
		tr			
			td
				font-size 12*$px
			td:nth-child(1)
				padding-left 0rem			
@media (max-width: 1000px)
	.fx-tb,.fx-tbl
		thead
			tr
				th
					font-weight 380
					font-size 12*$px
		tr			
			td
				font-size 11*$px
				padding-left 0rem
			td:nth-child(1)
				padding-left 0rem			
@media (max-width: 800px)
	.fx-tb,.fx-tbl
		thead
			tr
				th
					font-weight 370
					font-size 11*$px
					padding 1*$px 5*$px
		tr			
			td
				font-size 10*$px
				padding-left 0rem
			td:nth-child(1)
				padding-left 0rem